# Copy to app/.env.local or app/src-tauri/.env.local for local builds.
# Never commit real values.

# In-app "Report bug" issues
LINEAR_API_KEY=lin_api_your_key
LINEAR_TEAM_ID=your-linear-team-uuid
LINEAR_BUG_LABEL_NAME=User Bug

# Optional product infrastructure
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Sign-in (GCP Identity Platform / Firebase Auth). The Firebase web config is
# public by design. GOOGLE_DESKTOP_CLIENT_SECRET is a non-confidential
# installed-app secret (Google "Desktop app" client), NOT a server secret.
# Microsoft desktop is a public PKCE client, so it has no secret.
# Never commit real values.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
GOOGLE_DESKTOP_CLIENT_ID=
GOOGLE_DESKTOP_CLIENT_SECRET=
MICROSOFT_DESKTOP_CLIENT_ID=
SENTRY_DSN=
# Dev builds suppress Sentry by default so dev errors don't pollute the prod
# project. Set to 1 (or true/yes/on) to send + symbolicate while testing crash
# reporting from `pnpm tauri dev` or the web dev server. Ignored by release
# builds. (HOU-469)
SENTRY_SEND_IN_DEV=
