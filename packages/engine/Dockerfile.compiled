# syntax=docker/dockerfile:1

# Houston TS engine — COMPILED single-binary image (alternative to ./Dockerfile).
#
# ./Dockerfile ships the Bun runtime + node_modules + TS source and runs
# `bun run src/main.ts`. THIS file instead compiles the engine to one standalone
# executable with `bun build --compile`, then ships only that binary on a slim
# Debian base — no Bun runtime, no node_modules, no TS source in the final image.
#
# Same build-context rule as ./Dockerfile: context is packages/ (the engine
# links its sibling @houston/engine-client via file:../engine-client; that import
# is type-only, so it is erased from the compiled output).
#
#   docker build -f packages/engine/Dockerfile.compiled -t houston/ts-engine:compiled ./packages
#   docker run --rm -p 4317:4317 -e HOUSTON_ENGINE_TOKEN=... \
#     -v houston-data:/data -v houston-workspace:/workspace houston/ts-engine:compiled
#
# See README.md "Deploy (Docker / VPS)" for the full guide.

# ---------- build stage: compile to a standalone binary ----------
FROM oven/bun:1.3-debian AS build
WORKDIR /app

# engine-client must be present for bun to resolve file:../engine-client.
COPY engine-client/ /app/engine-client/
COPY engine/package.json engine/bun.lock /app/engine/
WORKDIR /app/engine
RUN bun install --frozen-lockfile
COPY engine/ /app/engine/

# Embeds the Bun runtime + every imported dependency into one executable.
# bun-linux-x64 = glibc, matching the debian-slim runtime stage below
# (swap for bun-linux-x64-musl if you base the runtime on Alpine).
RUN bun build --compile --target=bun-linux-x64 --sourcemap \
      src/main.ts --outfile /tmp/houston-engine

# ---------- runtime stage: just the binary + the tools the agent shells out to ----------
FROM debian:bookworm-slim
# bash + coreutils ship in the base; git + python3 are what the agent reaches for
# through its bash tool, curl is for the healthcheck, ca-certs for outbound HTTPS.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git python3 ca-certificates curl \
 && rm -rf /var/lib/apt/lists/* \
 && useradd --create-home --home-dir /home/bun --uid 1000 bun \
 && mkdir -p /data /workspace && chown -R bun:bun /data /workspace

COPY --from=build /tmp/houston-engine /usr/local/bin/houston-engine

ENV NODE_ENV=production \
    HOUSTON_HOST=0.0.0.0 \
    HOUSTON_PORT=4317 \
    HOUSTON_DATA_DIR=/data \
    HOUSTON_WORKSPACE_DIR=/workspace
# HOUSTON_MODEL intentionally unset (default lives in src/config.ts: claude-sonnet-4-6).
# HOUSTON_ENGINE_TOKEN must be provided at runtime, or the engine is open.

USER bun
WORKDIR /home/bun
EXPOSE 4317

# /health is public (no token). curl, since there's no bun in this image.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -fsS "http://127.0.0.1:${HOUSTON_PORT:-4317}/health" || exit 1

CMD ["/usr/local/bin/houston-engine"]
