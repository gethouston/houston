# ---- Houston TS engine — deployment config ----
# Copy this file to `.env` (same directory) before `docker compose up`.

# REQUIRED. Bearer token the engine demands on every API request. Leave it unset
# and the engine is open to anyone who can reach the port: they could drive the
# agent, run shell commands in the workspace, and spend your Claude
# subscription. Generate a strong one:
#   openssl rand -hex 32
HOUSTON_RUNTIME_TOKEN=

# Host port to publish the engine on. The container always listens on 4317
# internally; change only the host side here to avoid conflicts on the VPS.
HOUSTON_HOST_PORT=4317

# Optional. The engine already defaults to claude-sonnet-4-6
# (packages/runtime/src/config.ts). Uncomment only to pin a different Claude model.
# HOUSTON_MODEL=claude-sonnet-4-6

# CORS origin allowed to call the API from a browser. "*" is acceptable behind
# the token; set your webapp's exact origin (e.g. https://app.example.com) to
# tighten it for production.
HOUSTON_CORS_ORIGIN=*

# Runtime-local structured logs. File output is always on; terminal output is
# opt-in so Docker/app logs stay quiet unless requested.
# HOUSTON_RUNTIME_LOG_FILE=/data/runtime.log
# HOUSTON_RUNTIME_LOG_LEVEL=INFO
# HOUSTON_RUNTIME_PRINT_LOGS=1
