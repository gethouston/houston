{
  "name": "@houston/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "dev": "tsgo -p tsconfig.json --watch",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@houston/fake-host": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@houston/protocol": "workspace:*",
    "@houston/runtime-client": "workspace:*"
  }
}
