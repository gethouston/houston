    "@houston-ai/agent-schemas": "workspace:*",
    "@houston/protocol": "workspace:*",
    "croner": "10.0.1",
    "fflate": "0.8.3",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "typescript": "6.0.3",
    "vitest": "3.2.6"
  }
}
