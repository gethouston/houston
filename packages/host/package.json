    "@houston/protocol": "file:../protocol",
    "@houston/runtime-client": "file:../runtime-client"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22",
    "@typescript/native-preview": "7.0.0-dev.20260607.1"
  }
