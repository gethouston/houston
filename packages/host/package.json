{
  "name": "@houston/host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./src/vfs": "./src/vfs/index.ts",
    "./src/*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "tsx src/local/main.ts",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@executor-js/plugin-mcp": "1.5.32",
    "@executor-js/plugin-openapi": "1.5.32",
    "@executor-js/sdk": "1.5.32",
    "@houston/agentstore-contract": "workspace:*",
    "@houston/domain": "workspace:*",
    "@houston/protocol": "workspace:*",
    "@houston/runtime-client": "workspace:*",
    "@secretlint/core": "13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "effect": "4.0.0-beta.59",
    "fflate": "0.8.3",
    "tsx": "4.23.0"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "vitest": "3.2.6"
  }
}
