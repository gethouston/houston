{
  "name": "@houston/host-cloud",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env.local --import tsx src/main.ts",
    "dev:cloud": "node --import tsx src/main.ts",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "@google-cloud/storage": "7.21.0",
    "@houston/host": "workspace:*",
    "@houston/protocol": "workspace:*",
    "@houston/runtime-client": "workspace:*",
    "@kubernetes/client-node": "1.4.0",
    "ioredis": "5.11.1",
    "jose": "5.10.0",
    "pg": "8.22.0",
    "tsx": "4.23.0"
  },
  "devDependencies": {
    "@types/ioredis-mock": "8.2.7",
    "@types/node": "22.20.0",
    "@types/pg": "8.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "ioredis-mock": "8.13.1",
    "pg-mem": "3.0.14",
    "vitest": "3.2.6"
  }
}
