{
  "name": "@houston/fake-host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "In-memory protocol-v3 Houston host for UI/e2e tests. Shares the real server streaming pieces (StreamChannel, serveResumableStream, formatSseFrame) so the mock can't drift from the wire contract.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "tsx src/main.ts",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@houston/protocol": "workspace:*",
    "@houston/runtime-client": "workspace:*",
    "fflate": "0.8.3"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "3.2.6"
  }
}
