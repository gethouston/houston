{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Activity",
  "description": "List of board items for a Houston agent.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "description", "status"],
    "properties": {
      "id": { "type": "string" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "status": {
        "type": "string",
        "enum": ["running", "needs_you", "done", "error", "archived"]
      },
      "claude_session_id": { "type": ["string", "null"] },
      "session_key": { "type": "string" },
      "agent": { "type": "string" },
      "worktree_path": { "type": ["string", "null"] },
      "routine_id": { "type": "string" },
      "routine_run_id": { "type": "string" },
      "skill_slug": {
        "type": "string",
        "description": "The installed skill (directory slug) this setup chat belongs to. Set by Houston, not by the agent."
      },
      "updated_at": { "type": "string", "format": "date-time" },
      "provider": { "type": "string" },
      "model": { "type": "string" },
      "created_by": {
        "type": "string",
        "description": "The human who created this mission. Set by Houston, not by the agent."
      },
      "contributors": {
        "type": "array",
        "description": "Humans who started or collaborated on this mission. Set by Houston, not by the agent.",
        "items": {
          "type": "object",
          "required": ["user_id"],
          "additionalProperties": false,
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      },
      "pending_interaction": {
        "type": "object",
        "description": "The ordered steps this mission is waiting on the user for, walked one at a time: question steps first (at most 3), then at most one signin step, then connect steps, then approval steps (last, since approving happens after connecting).",
        "required": ["steps"],
        "properties": {
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "id"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "question",
                    "signin",
                    "connect",
                    "plan_ready",
                    "suggest_reusable",
                    "approval"
                  ]
                },
                "id": { "type": "string" },
                "question": { "type": "string" },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label"],
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" },
                      "description": { "type": "string" },
                      "recommended": { "type": "boolean" }
                    }
                  }
                },
                "toolkit": { "type": "string" },
                "reason": { "type": "string" },
                "summary": { "type": "string" },
                "reusableKind": {
                  "type": "string",
                  "enum": ["skill", "routine"]
                },
                "title": { "type": "string" },
                "rationale": { "type": "string" },
                "action": { "type": "string" },
                "params": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "paramsOmitted": { "type": "number" },
                "paramsHash": { "type": "string" }
              },
              "oneOf": [
                {
                  "properties": { "kind": { "const": "question" } },
                  "required": ["question"]
                },
                {
                  "properties": { "kind": { "const": "signin" } }
                },
                {
                  "properties": { "kind": { "const": "connect" } },
                  "required": ["toolkit"]
                },
                {
                  "properties": { "kind": { "const": "plan_ready" } },
                  "required": ["summary"]
                },
                {
                  "properties": { "kind": { "const": "suggest_reusable" } },
                  "required": ["reusableKind", "title", "rationale"]
                },
                {
                  "properties": { "kind": { "const": "approval" } },
                  "required": ["toolkit", "action", "paramsHash"]
                }
              ]
            }
          }
        }
      }
    },
    "additionalProperties": false
  }
}
