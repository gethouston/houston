{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Activity",
  "description": "List of board items for a Houston agent.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "description", "status"],
    "properties": {
      "id": { "type": "string" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "status": {
        "type": "string",
        "enum": ["running", "needs_you", "done", "error", "archived"]
      },
      "claude_session_id": { "type": ["string", "null"] },
      "session_key": { "type": "string" },
      "agent": { "type": "string" },
      "worktree_path": { "type": ["string", "null"] },
      "routine_id": { "type": "string" },
      "routine_run_id": { "type": "string" },
      "updated_at": { "type": "string", "format": "date-time" },
      "provider": { "type": "string" },
      "model": { "type": "string" },
      "pending_interaction": {
        "type": "object",
        "description": "The one thing this mission is waiting on the user for.",
        "required": ["kind"],
        "properties": {
          "kind": { "type": "string", "enum": ["question", "connect"] },
          "questions": {
            "type": "array",
            "description": "1 to 3 questions asked together as one card.",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["id", "question"],
              "properties": {
                "id": { "type": "string" },
                "question": { "type": "string" },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label"],
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "toolkit": { "type": "string" },
          "reason": { "type": "string" }
        },
        "oneOf": [
          {
            "properties": { "kind": { "const": "question" } },
            "required": ["questions"]
          },
          {
            "properties": { "kind": { "const": "connect" } },
            "required": ["toolkit"]
          }
        ]
      }
    },
    "additionalProperties": false
  }
}
