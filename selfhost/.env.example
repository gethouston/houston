# Houston self-host configuration. Copy to `.env` and fill in.
#   cp .env.example .env

# The public hostname for this VPS. Must already resolve here (an A/AAAA DNS
# record) so Caddy can complete the Let's Encrypt challenge on first boot.
HOUSTON_DOMAIN=houston.example.com

# The shared secret every request must carry (Authorization: Bearer <token>).
# This is the ONLY thing standing between the internet and your agents — make it
# long and random. Generate one with:
#   openssl rand -hex 32
HOUSTON_HOST_TOKEN=

# Optional: which host port the published proxy maps from is fixed at 80/443 in
# the compose file (Caddy needs them for ACME + HTTPS). The engine's in-container
# port (4318) almost never needs changing.
