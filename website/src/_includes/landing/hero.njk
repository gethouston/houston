{% from "houston-logo.njk" import houstonLogo %}
<header class="hero">
  <div class="hero-inner">
    <h1 class="hero-load">AI agents that do<br><span class="hero-cycling-word" id="hero-cycling"></span></h1>
    <p class="hero-sub hero-load">One free desktop app that runs on your GPT subscription.<br>A workspace of pre-built AI agents that actually do the work.</p>
    <div class="hero-actions hero-load">
      <button class="btn btn-ink" data-dl-trigger data-dl-source="hero">{{ houstonLogo(18) }} Download App</button>
    </div>
  </div>

  <div class="hero-frame hero-load">
    <div class="hero-stage">
      {# The scripted demo (assets/hero-demo*.js) animates INSIDE this real-app
         board: an agent switch + a Running→Done card, looping across the team.
         Progressive: JS-off / reduced-motion leaves the finished state below. #}
      <div class="win" data-hero-demo role="img" aria-label="Houston, the desktop app: a mission board where agents move tasks across Running, Needs you, and Done columns">
        <div class="win-body">
          <aside class="sb">
            <span class="sb-lights" aria-hidden="true"><i class="tl-r"></i><i class="tl-y"></i><i class="tl-g"></i></span>
            <div class="sb-ws">
              <span class="ws-name">Personal<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg></span>
              <svg class="ws-collapse" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
            </div>
            <div class="nav-item on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>Mission Control</div>
            <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M5 7h4V3h6v4h4v6h-4v-2a2 2 0 0 0-4 0v2H5z"/><path d="M5 13h4a2 2 0 0 1 0 4H5v4h6"/></svg>Integrations</div>
            <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 3l1.9 4.6L18.5 9l-4.6 1.9L12 15l-1.9-4.1L5.5 9l4.6-1.4z"/><circle cx="18" cy="17" r="2"/><circle cx="6" cy="17" r="2"/></svg>AI Models</div>
            <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M3 12a9 9 0 1 1 18 0"/><path d="M12 12l4-2"/></svg>Usage</div>
            <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M4 8h16l-1 3a3 3 0 0 1-6 0 3 3 0 0 1-6 0z"/><path d="M5 11v9h14v-9"/><path d="M4 8l2-4h12l2 4"/></svg>Agent Store</div>
            <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19 12a7 7 0 0 0-.1-1l2-1.5-2-3.4-2.3 1a7 7 0 0 0-1.7-1l-.3-2.5H10l-.3 2.5a7 7 0 0 0-1.7 1l-2.3-1-2 3.4 2 1.5a7 7 0 0 0 0 2l-2 1.5 2 3.4 2.3-1a7 7 0 0 0 1.7 1l.3 2.5h3.6l.3-2.5a7 7 0 0 0 1.7-1l2.3 1 2-3.4-2-1.5a7 7 0 0 0 .1-1z"/></svg>Settings</div>
            <div class="sb-group"><span class="sg-label">Your Agents</span><svg class="sg-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M17 8h5M19.5 5.5v5"/></svg><svg class="sg-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg></div>
            <div class="agent-row on" data-agent="houston"><span class="av av-p" aria-hidden="true">H</span><span class="a-name">Houston</span><span class="a-count">1</span></div>
            <div class="agent-row" data-agent="chief-of-staff"><span class="av av-b" aria-hidden="true">CS</span><span class="a-name">Chief of Staff</span><span class="a-count">2</span></div>
            <div class="agent-row" data-agent="bookkeeper"><span class="av av-o" aria-hidden="true">BK</span><span class="a-name">Bookkeeper</span></div>
            <div class="agent-row" data-agent="sales-rep"><span class="av av-c" aria-hidden="true">SR</span><span class="a-name">Sales Rep</span><span class="a-count">1</span></div>
          </aside>

          <section class="screen">
            <div class="screen-head">
              <span class="sh-title" id="hd-board-title">Houston</span>
              <span class="sh-search"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>Search missions</span>
              <span class="sh-guide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2 5-5 2 2-5z"/></svg>Guide me</span>
              <span class="sh-new"><span class="glyph" aria-hidden="true"></span>New mission</span>
            </div>
            <div class="tabs">
              <span class="tab on">Activity<span class="t-count" id="hd-activity-count">1</span></span>
              <span class="tab">Routines</span>
              <span class="tab">Integrations</span>
              <span class="tab">Files</span>
              <span class="tab">Archived</span>
              <span class="tab">Agent Settings</span>
            </div>
            <div class="cols">
              <div class="col">
                <div class="col-h">Running<span class="c-count" id="hd-run-count">0</span><span class="c-menu" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg></span></div>
                <div class="card-add"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg></div>
                <div class="col-body" id="hd-running"></div>
              </div>
              <div class="col">
                <div class="col-h">Needs you<span class="c-count">1</span><span class="c-menu" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg></span></div>
                <div class="col-body">
                  <div class="tcard">
                    <div class="tc-head"><span class="av av-p" id="hd-needs-avatar" aria-hidden="true">H</span><span class="tc-agent" id="hd-needs-agent">Houston</span><span class="tc-actions" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M20 6L9 17l-5-5"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 7h16M9 7V4h6v3M6 7l1 13h10l1-13"/></svg></span></div>
                    <div class="tc-title" id="hd-needs-title">Plan a trip to Tokyo</div>
                    <div class="tc-desc" id="hd-needs-desc">Research flights and hotels for the spring</div>
                  </div>
                </div>
              </div>
              <div class="col">
                <div class="col-h">Done<span class="c-count" id="hd-done-count">1</span><span class="c-menu" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg></span></div>
                <div class="col-body" id="hd-done">
                  <div class="tcard">
                    <div class="tc-head"><span class="av av-p" aria-hidden="true">H</span><span class="tc-agent">Houston</span><span class="tc-actions" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 7h16M9 7V4h6v3M6 7l1 13h10l1-13"/></svg></span></div>
                    <div class="tc-title">Follow up on urgent email</div>
                    <div class="tc-desc">4 replies ready, 17 archived</div>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</header>
