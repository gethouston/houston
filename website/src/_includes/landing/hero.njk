<header class="hero">
  <div class="hero-sky" aria-hidden="true">
    <picture>
      <source type="image/avif" sizes="100vw"
              srcset="/assets/space/milkyway-1280.avif 1280w, /assets/space/milkyway-1920.avif 1920w, /assets/space/milkyway-2560.avif 2560w">
      <source type="image/webp" sizes="100vw"
              srcset="/assets/space/milkyway-1280.webp 1280w, /assets/space/milkyway-1920.webp 1920w, /assets/space/milkyway-2560.webp 2560w">
      <img src="/assets/space/milkyway-1920.jpg" sizes="100vw"
           srcset="/assets/space/milkyway-1280.jpg 1280w, /assets/space/milkyway-1920.jpg 1920w, /assets/space/milkyway-2560.jpg 2560w"
           width="2560" height="1440"
           alt="The Milky Way arching over a dark horizon"
           decoding="async" fetchpriority="high">
    </picture>
  </div>
  <div class="hero-veil" aria-hidden="true"></div>
  <div class="hero-bloom" aria-hidden="true"></div>

  <div class="hero-inner">
    <span class="hero-eyebrow hero-load"><span class="dot" aria-hidden="true"></span>Mission control for your work</span>
    <h1 class="hero-load">Get real work done for you, <span class="accent">without the busywork</span>.</h1>
    <p class="hero-sub hero-load">Houston is a tiny desktop app where you hire a team of AI agents that actually do the work. Built for people who don't code, with no prompts to engineer and no one new to manage.</p>
    <div class="hero-actions hero-load">
      <button class="btn btn-white" data-dl-trigger data-dl-source="hero">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.5 3c.1 1-.3 2-1 2.8-.7.8-1.7 1.4-2.7 1.3-.1-1 .4-2 1-2.7.7-.8 1.9-1.4 2.7-1.4zM19 17.4c-.4 1-.6 1.4-1.1 2.3-.8 1.3-1.9 2.9-3.3 2.9-1.2 0-1.5-.8-3.2-.8s-2 .8-3.2.8c-1.4 0-2.4-1.4-3.2-2.7C2.5 16.8 2.3 12.7 4 10.5c.9-1.2 2.3-1.9 3.6-1.9 1.4 0 2.2.8 3.3.8 1.1 0 1.7-.8 3.3-.8 1.2 0 2.4.6 3.3 1.7-2.9 1.6-2.4 5.7.5 7.1z"/></svg>
        Download App
      </button>
      <a class="btn btn-ghost" href="#how">See how it works</a>
    </div>
    <div class="hero-proof hero-load">
      <span>Free to start</span><span class="sep" aria-hidden="true"></span>
      <span>Runs on the ChatGPT or Claude plan you already pay for</span><span class="sep" aria-hidden="true"></span>
      <span>1,000+ integrations</span>
    </div>
  </div>

  <div class="hero-stage hero-load" role="img" aria-label="Houston Mission Control: an agent moving tasks across a board while it works">
    <div class="win">
      <div class="win-bar">
        <span class="lights" aria-hidden="true"><i class="tl-r"></i><i class="tl-y"></i><i class="tl-g"></i></span>
        <span class="win-title">Houston — Acme Studio</span>
      </div>
      <div class="win-body">
        <aside class="sb">
          <div class="sb-ws">
            <span class="ws-badge" aria-hidden="true">A</span>
            <span class="ws-name">Acme Studio<small>Personal workspace</small></span>
          </div>
          <div class="nav-item on"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>Mission board</div>
          <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Chats</div>
          <div class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>Files</div>
          <div class="sb-group">Agents</div>
          <div class="agent-row on"><span class="av av-o" aria-hidden="true">RO</span><span class="a-name">Rosa · Ops</span><span class="a-live" aria-hidden="true"></span></div>
          <div class="agent-row"><span class="av av-b" aria-hidden="true">LE</span><span class="a-name">Leo · Research</span><span class="a-count">4</span></div>
          <div class="agent-row"><span class="av av-p" aria-hidden="true">MI</span><span class="a-name">Mira · Finance</span><span class="a-count">2</span></div>
          <div class="agent-row"><span class="av av-g" aria-hidden="true">SA</span><span class="a-name">Sam · Outreach</span><span class="a-count">7</span></div>
        </aside>
        <section class="board">
          <div class="board-head">
            <div>
              <h3>Rosa · Operations</h3>
              <div class="b-sub">Working across Gmail, Notion, and Stripe</div>
            </div>
            <span class="pill"><span class="a-live" aria-hidden="true"></span>Live</span>
          </div>
          <div class="cols">
            <div class="col">
              <div class="col-h"><span class="cdot cd-todo" aria-hidden="true"></span>To do</div>
              <div class="card"><div class="c-title">Draft Q3 vendor renewal emails</div><div class="c-foot"><span class="c-tag">Gmail</span></div></div>
              <div class="card"><div class="c-title">Reconcile last week's expenses</div><div class="c-foot"><span class="c-tag">Stripe</span></div></div>
            </div>
            <div class="col">
              <div class="col-h"><span class="cdot cd-prog" aria-hidden="true"></span>In progress</div>
              <div class="card running">
                <div class="c-title">Compile the investor update from this month's metrics</div>
                <span class="run-tag"><span class="rdot" aria-hidden="true"></span>Rosa is working</span>
                <div class="bar" aria-hidden="true"><i></i></div>
              </div>
              <div class="card"><div class="c-title">Schedule 6 customer calls for Thursday</div><div class="c-foot"><span class="c-tag">Calendar</span></div></div>
            </div>
            <div class="col col-done">
              <div class="col-h"><span class="cdot cd-done" aria-hidden="true"></span>Done</div>
              <div class="card"><div class="c-title">Sorted 214 support tickets into themes</div><div class="c-foot"><span class="c-tag">Notion</span></div></div>
              <div class="card"><div class="c-title">Published the weekly team digest</div><div class="c-foot"><span class="c-tag">Slack</span></div></div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</header>
