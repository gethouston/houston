<section id="pricing" class="section band-paper-raised">
  <div class="pricing-head reveal">
    <div class="eyebrow-mono on-paper" style="justify-content:center">Pricing</div>
    <h2 class="sec-title">The app is free. Forever.</h2>
    <p class="sec-lead">Add your team when you are ready, and only pay for the people who actually join.</p>
  </div>

  <div class="pricing-grid reveal reveal-d1">
    <div class="price-col">
      <div class="price-name">Personal</div>
      <div class="price-amt"><span class="amount">Free</span></div>
      <div class="price-note"></div>
      <p class="price-desc">Runs on your computer. Bring your own ChatGPT or Claude plan.</p>
      <div class="price-cta"><button class="btn btn-ink" data-dl-trigger data-dl-source="pricing">Download App</button></div>
      <div class="price-list-intro">Everything you need:</div>
      <ul class="price-feats">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Unlimited agents, every feature included</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Desktop app plus phone companion</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>1,000+ integrations</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>No credit card, ever</li>
      </ul>
    </div>

    <div class="price-col featured">
      <div class="price-name">Team</div>
      <div class="price-amt"><span class="amount">{{ pricing.currency }}{{ pricing.teamMonthly }}</span><span class="per">/seat/mo</span></div>
      <div class="price-note">{{ pricing.currency }}{{ pricing.teamAnnual }}/seat/mo billed annually</div>
      <p class="price-desc">Your agents run around the clock, even when your laptop is closed.</p>
      <div class="price-cta"><button class="btn btn-ember" data-dl-trigger data-dl-source="pricing-team">Start free trial</button></div>
      <div class="price-list-intro">Everything in Personal, plus:</div>
      <ul class="price-feats">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>24/7 agents, scheduled tasks fire on time</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Shared agents, web app access</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Roles and access control</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg><div>{{ pricing.trialDays }}-day free trial, no card to start<div class="price-feat-note">Starts when your second member accepts</div></div></li>
      </ul>
    </div>

    <div class="price-col">
      <div class="price-name">Enterprise</div>
      <div class="price-amt"><span class="amount">Custom</span></div>
      <div class="price-note"></div>
      <p class="price-desc">Security and scale for bigger teams, with custom agents for your business.</p>
      <div class="price-cta"><a class="btn btn-outline" href="mailto:{{ pricing.salesEmail }}?subject=Houston%20Enterprise">Talk to us</a></div>
      <div class="price-list-intro">Everything in Team, plus:</div>
      <ul class="price-feats">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Single sign-on (SSO), uptime SLA</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Priority support in English and Spanish</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>Private deployment, onboarding included</li>
      </ul>
    </div>
  </div>
</section>
