# Houston Agent Store environment template.
#
# Local dev (`next dev`): copy to `.env.local`.
# Production: set these on the GKE Deployment (plain env for the public values,
# a Secret for nothing here — every value below is safe to ship to the browser
# EXCEPT AGENTSTORE_GATEWAY_URL, which stays server-side).
#
# The store is a pure SSR frontend for the Houston gateway's Agent Store API
# (/v1/agentstore/*). It holds no database and no service credentials.

# ---------------------------------------------------------------------------
# Gateway API base URLs
# ---------------------------------------------------------------------------
# Server-side base the SSR reads for public catalog/agent/sitemap fetches. NOT
# exposed to the browser. Defaults to https://gateway.gethouston.ai when unset,
# so `next build` needs no value.
AGENTSTORE_GATEWAY_URL=https://gateway.gethouston.ai

# Client-side base for authed + anonymous mutations made directly from the
# browser (sign-in bearer, claim, publish, reports). NEXT_PUBLIC_* is inlined at
# build time. Point at the same gateway; the gateway must allow CORS from this
# store's origin for the authed/mutation routes.
NEXT_PUBLIC_AGENTSTORE_GATEWAY_URL=https://gateway.gethouston.ai

# ---------------------------------------------------------------------------
# Site identity
# ---------------------------------------------------------------------------
# Canonical public site URL (OG tags, share/schema links, claim URLs). Inlined
# at build time. Defaults to https://store.gethouston.ai when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3300

# ---------------------------------------------------------------------------
# Firebase / Google Cloud Identity Platform (sign-in)
# ---------------------------------------------------------------------------
# The SAME Firebase (GCIP) project the gateway verifies bearer tokens against.
# All three are safe to expose to the browser (Firebase web config is public).
# Leave them blank to build a preview with sign-in disabled (the header shows no
# account control and /me, /admin, and /claim report that sign-in is unavailable).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
