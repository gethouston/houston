{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "houston-agentstore",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-01",
  // nodejs_compat is required by @opennextjs/cloudflare (postgres driver, Node
  // globals). Keep it in lockstep with a compatibility_date >= 2024-09-23.
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
