{
  "name": "houston-ai",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --write --error-on-warnings",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:parity": "node scripts/check-parity.mjs",
    "prepare": "husky || true",
    "test": "pnpm -r --if-present --no-bail test",
    "start": "pnpm install && pnpm dev",
    "dev": "mprocs",
    "dev:host": "set -a; [ -f .env.local ] && . ./.env.local; set +a; HOUSTON_HOME=\"${HOUSTON_HOME:-$HOME/.dev-houston}\" HOUSTON_HOST_TOKEN=\"${HOUSTON_HOST_TOKEN:-devtoken}\" HOUSTON_HOST_PORT=\"${HOUSTON_HOST_PORT:-4318}\" pnpm --filter @houston/host dev",
    "dev:app": "set -a; [ -f .env.local ] && . ./.env.local; set +a; cd app && VITE_NEW_ENGINE_URL=\"${VITE_NEW_ENGINE_URL:-http://127.0.0.1:4318}\" VITE_NEW_ENGINE_TOKEN=\"${VITE_NEW_ENGINE_TOKEN:-devtoken}\" VITE_HOSTED_ENGINE_URL=\"${VITE_HOSTED_ENGINE_URL:-}\" pnpm tauri dev",
    "dev:cloud": "./scripts/dev-cloud.sh",
    "dev:cloud:app": "./scripts/dev-cloud.sh --app",
    "dev:cloud:retain": "./scripts/dev-cloud.sh --retain",
    "dev:cloud:down": "./scripts/dev-cloud.sh --down",
    "ios": "bash mobile/ios/scripts/dev-sim.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "esbuild": "0.25.12",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "mprocs": "0.9.6",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "3.2.6",
    "yaml": "2.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": "biome check --write --no-errors-on-unmatched --error-on-warnings"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
