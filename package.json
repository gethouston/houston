{
  "name": "houston-ai",
  "version": "0.5.9",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --write --error-on-warnings",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:parity": "node scripts/check-parity.mjs",
    "prepare": "husky || true",
    "test": "pnpm -r --if-present --no-bail test",
    "start": "node scripts/dev/wrong-entry.mjs start",
    "dev:cloud": "node scripts/dev/wrong-entry.mjs dev:cloud",
    "dev": "scripts/dev/dev.sh",
    "dev:down": "scripts/dev/reap.sh",
    "dev:host": ". scripts/dev/env.sh && HOUSTON_HOME=\"$HOME/.dev-houston\" pnpm --filter @houston/host dev",
    "dev:app": "scripts/dev/app.sh",
    "ios": "bash mobile/ios/scripts/dev-sim.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "esbuild": "0.25.12",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "mprocs": "0.9.6",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "3.2.6",
    "yaml": "2.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": "biome check --write --no-errors-on-unmatched --error-on-warnings"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
