{
  "name": "houston-ai",
  "version": "0.4.12",
  "private": true,
  "type": "module",
  "workspaces": [
    "ui/*",
    "app",
    "mobile",
    "houston-relay",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "bash -c 'bun run typecheck'",
      "bash -c 'bun --filter houston-app check-locales'"
    ],
    "*.rs": [
      "rustfmt --edition 2021 --check"
    ],
    "package.json": [
      "./scripts/cargo-sync-check.sh"
    ]
  }
}
